# Django REST Framework API root. Do not add a trailing slash.
VITE_API_BASE_URL=http://localhost:8000/api

# Optional development-server overrides. Without these, Vite uses localhost:5173.
# VITE_DEV_HOST=localhost
# VITE_DEV_PORT=5173

# The live Django API is used by default. Set true only for offline UI work.
VITE_USE_MOCK_API=false
