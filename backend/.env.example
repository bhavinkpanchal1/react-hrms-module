DJANGO_SECRET_KEY=replace-this-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Asia/Kolkata
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local development is anonymous because the React login screen is currently
# a placeholder. Set this to false to require JWT or session authentication.
API_ALLOW_ANONYMOUS=true

# Leave DB_ENGINE unset to use backend/db.sqlite3.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hrms
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
